# Snowflake Kafka Connector - Docker Test Environment
# Copy this file to .env and fill in your values

# Required: Path to your Snowflake credentials JSON file
SNOWFLAKE_CREDENTIAL_FILE=/path/to/your/profile.json

# Confluent Platform version (6.2.x or 7.8.x)
CONFLUENT_VERSION=7.8.0

# Optional: Specific tests to run (comma-separated)
# TESTS_TO_RUN=TestStringJson,TestAvro

# Optional: Enable pressure testing
# PRESSURE_TEST=true
